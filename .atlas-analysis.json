  "projectDescription": "A distributed, RESTful search and analytics engine built on Apache Lucene, optimized for near real-time full-text search, vector search, and large-scale data analytics.",
  "theme": "aspen",
  "primaryColor": "#0dabc7",
  "lightColor": "#8bc404",
